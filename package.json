{
  "name": "pipertts",
  "version": "1.0.0",
  "description": "TypeScript wrapper for PiperTTS with bundled binaries for Windows and Linux",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "bin/**/*",
    "README.md"
  ],
  "scripts": {
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "example": "ts-node --esm examples/example.ts",
    "format": "bunx --bun @biomejs/biome format --write ./src",
    "check": "bunx --bun @biomejs/biome check ./src",
    "lint": "bunx --bun @biomejs/biome lint ./src",
    "lint:write": "bunx --bun @biomejs/biome lint --write ./src",
    "test": "bunx --bun @biomejs/biome test ./src",
    "build": "tsc --project tsconfig.json",
    "deploy:npm": "npm publish --access public",
    "publish-package": "bash ./scripts/publish-package.sh",
    "bench": "rm -rf .benchmark-shells/ && bun benchmark-virtualshell.ts",
    "standalone-build": "bunx esbuild src/standalone.ts --bundle --platform=node --target=node18 --outfile=standalone.js --tree-shaking=true --minify --sourcemap"
  },
  "keywords": [
    "piper",
    "tts",
    "text-to-speech",
    "speech-synthesis"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@types/bun": "latest"
  }
}
